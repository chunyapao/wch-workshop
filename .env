# =============================================================================
# การตั้งค่า Pretraining (Continued Pre-training)
# =============================================================================

# ขนาดของแต่ละก้อนข้อมูล (Token)
# - ค่าน้อย: ได้จำนวนก้อนมาก แต่บริบทสั้น
# - ค่ามาก: ได้จำนวนก้อนน้อย แต่บริบทยาว
# แนะนำ: 128 สำหรับข้อมูลภาษาไทย
BLOCK_SIZE=128

# ความยาวสูงสุดของข้อความตอนเทรน (ต้องมากกว่า BLOCK_SIZE เล็กน้อย)
MAX_SEQ_LENGTH=130

# =============================================================================
# การตั้งค่า Fine-tuning
# =============================================================================

# จำนวนรอบการเทรน
# - 100: สำหรับข้อมูลน้อย + ป้องกัน overfitting (แนะนำสำหรับ POC)
# - 500: เทรนปานกลาง (สำหรับข้อมูลมาก)
# - 1000+: เทรนนาน (สำหรับข้อมูลมาก)
TRAINING_ITERS=200

# จำนวนตัวอย่างที่ประมวลผลพร้อมกัน
# - 1: สำหรับ RAM 8GB และข้อมูลน้อย (แนะนำ)
# - 2: สำหรับ RAM 16GB
# - 4: สำหรับ RAM 32GB+
BATCH_SIZE=1

# อัตราการเรียนรู้ (Learning Rate)
# - 3e-5: ค่ามาตรฐาน (แนะนำ)
# - 1e-5: เรียนรู้ช้า แต่เสถียร
# - 5e-5: เรียนรู้เร็ว แต่อาจ overfit
LEARNING_RATE=1e-5

# =============================================================================
# การตั้งค่า LoRA
# =============================================================================

# จำนวนเลเยอร์ที่จะเพิ่ม LoRA (นับจากท้าย)
# - 8: ค่ามาตรฐาน
# - 16: เรียนรู้มากขึ้น (ใช้ RAM มากขึ้น)
LORA_NUM_LAYERS=8

# ขนาดของ Matrix ใน LoRA (Rank)
# - 8: ความสามารถจำกัด เหมาะกับข้อมูลน้อย (แนะนำสำหรับ POC)
# - 16: ค่ามาตรฐาน
# - 32: ความสามารถสูง (ใช้ RAM มากขึ้น)
LORA_RANK=8

# สเกลของ LoRA
# - 2.0: ค่ามาตรฐาน
LORA_SCALE=2.0

# Dropout (ป้องกัน Overfitting)
# - 0.05: สำหรับข้อมูลมาก
# - 0.1: สำหรับข้อมูลน้อย + ป้องกัน overfitting (แนะนำสำหรับ POC)
LORA_DROPOUT=0.1
